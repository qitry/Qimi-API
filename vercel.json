{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/openapi", "destination": "/api/openapi.ts" },
    { "source": "/api/openapi.json", "destination": "/api/openapi.ts" },
    { "source": "/api/openapi-spec.json", "destination": "/api/openapi-spec.json" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/openapi-spec.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
