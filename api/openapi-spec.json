{
  "openapi": "3.0.0",
  "info": {
    "title": "Qimi API",
    "description": "基于 Node.js/TypeScript 开发、符合 OpenAPI 规范的免费 API 服务集合",
    "version": "1.0.0"
  },
  "servers": [{ "url": "/", "description": "当前环境" }],
  "paths": {
    "/api/weather": {
      "get": {
        "summary": "天气查询",
        "description": "获取指定坐标的当前天气信息。支持通过 IP 自动定位。",
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "schema": { "type": "number" },
            "description": "纬度"
          },
          {
            "name": "longitude",
            "in": "query",
            "schema": { "type": "number" },
            "description": "经度"
          },
          {
            "name": "ip",
            "in": "query",
            "schema": { "type": "string" },
            "description": "指定 IP 自动定位"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/WeatherData"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/ip": {
      "get": {
        "summary": "IP 定位",
        "description": "查询 IP 或域名的地理位置信息。",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "schema": { "type": "string" },
            "description": "目标 IP 或域名"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "zh-CN" },
            "description": "返回语言"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/IpData"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "summary": "网页搜索",
        "description": "执行网页搜索，返回标题、描述和链接。",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "搜索关键词"
          },
          {
            "name": "count",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 },
            "description": "返回结果数量"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "zh" },
            "description": "语言代码: en, zh, ja, ko, fr, de, es, pt, ru, ar"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/SearchData"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/baidu": {
      "get": {
        "summary": "百度热搜",
        "description": "获取百度实时热搜榜单。",
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/BaiduHotItem" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/bilibili": {
      "get": {
        "summary": "B站热榜",
        "description": "获取B站热门视频榜单。",
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/BilibiliItem" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/history": {
      "get": {
        "summary": "历史上的今天",
        "description": "获取指定日期的历史大事件。",
        "parameters": [
          {
            "name": "month",
            "in": "query",
            "schema": { "type": "string" },
            "description": "月份 (01-12)，不填则返回当天"
          },
          {
            "name": "day",
            "in": "query",
            "schema": { "type": "string" },
            "description": "日期 (01-31)，不填则返回当天"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/HistoryItem" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/suggest": {
      "get": {
        "summary": "搜索联想",
        "description": "获取百度搜索联想词列表。",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "搜索关键词"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/SuggestData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/baidu-search": {
      "get": {
        "summary": "百度搜索 (Alpha)",
        "description": "获取百度搜索结果。状态: Alpha - 可能不稳定",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "搜索关键词"
          },
          {
            "name": "count",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 20, "default": 10 },
            "description": "返回结果数量"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BaiduSearchData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/lunar": {
      "get": {
        "summary": "今日农历",
        "description": "获取指定日期的农历信息，包括农历年月日、星期、节日、节气、宜忌等。",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "schema": { "type": "string", "format": "date" },
            "description": "日期 (YYYY-MM-DD)，不填则返回当天"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/LunarData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/60s": {
      "get": {
        "summary": "60秒读懂世界",
        "description": "获取每日60秒读懂世界简报，包含今日新闻摘要。",
        "parameters": [],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": { "type": "string" },
                          "description": "简报内容列表"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/hot": {
      "get": {
        "summary": "热搜榜",
        "description": "获取多平台实时热搜榜单（百度、微博、抖音、知乎等）。",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "description": "热搜类型: baidu, weibo, douyin, zhihu"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/HotSource" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "description": "统一 API 响应格式",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，200 表示成功，其他表示错误",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "状态信息",
            "example": "success"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "响应数据"
          }
        },
        "required": ["code", "message"]
      },
      "WeatherData": {
        "type": "object",
        "description": "天气数据",
        "properties": {
          "latitude": { "type": "number", "description": "纬度" },
          "longitude": { "type": "number", "description": "经度" },
          "current_weather": {
            "type": "object",
            "description": "当前天气",
            "properties": {
              "temperature": { "type": "number", "description": "温度" },
              "windspeed": { "type": "number", "description": "风速" },
              "winddirection": { "type": "number", "description": "风向" },
              "weathercode": { "type": "integer", "description": "天气代码" },
              "is_day": { "type": "integer", "description": "是否白天 (0/1)" },
              "time": { "type": "string", "description": "时间" }
            }
          }
        }
      },
      "IpData": {
        "type": "object",
        "description": "IP 定位数据",
        "properties": {
          "status": { "type": "string", "description": "状态 (success/fail)" },
          "country": { "type": "string", "description": "国家" },
          "countryCode": { "type": "string", "description": "国家代码" },
          "region": { "type": "string", "description": "省份/地区" },
          "regionName": { "type": "string", "description": "省份名称" },
          "city": { "type": "string", "description": "城市" },
          "zip": { "type": "string", "description": "邮政编码" },
          "lat": { "type": "number", "description": "纬度" },
          "lon": { "type": "number", "description": "经度" },
          "timezone": { "type": "string", "description": "时区" },
          "isp": { "type": "string", "description": "运营商" },
          "org": { "type": "string", "description": "组织/公司" },
          "as": { "type": "string", "description": "AS 号" },
          "query": { "type": "string", "description": "查询的 IP" }
        }
      },
      "SearchData": {
        "type": "object",
        "description": "搜索结果数据",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string", "description": "标题" },
                "link": { "type": "string", "description": "链接" },
                "description": { "type": "string", "description": "描述" },
                "pubDate": { "type": "string", "description": "发布日期" }
              }
            }
          },
          "count": { "type": "integer", "description": "结果总数" }
        }
      },
      "SearchResultItem": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "标题" },
          "link": { "type": "string", "description": "链接" },
          "description": { "type": "string", "description": "描述" },
          "pubDate": { "type": "string", "description": "发布日期" }
        }
      },
      "BaiduHotItem": {
        "type": "object",
        "description": "百度热搜条目",
        "properties": {
          "index": { "type": "integer", "description": "排名" },
          "title": { "type": "string", "description": "标题" },
          "hot": { "type": "string", "description": "热度指数" },
          "desc": { "type": "string", "description": "描述" },
          "image": { "type": "string", "description": "图片 URL" },
          "url": { "type": "string", "description": "链接" }
        }
      },
      "BilibiliItem": {
        "type": "object",
        "description": "B站视频条目",
        "properties": {
          "rank": { "type": "integer", "description": "排名" },
          "aid": { "type": "integer", "description": "稿件avid" },
          "bvid": { "type": "string", "description": "稿件bvid" },
          "title": { "type": "string", "description": "标题" },
          "url": { "type": "string", "description": "视频链接" },
          "cover": { "type": "string", "description": "封面图" },
          "author": { "type": "string", "description": "作者" },
          "authorFace": { "type": "string", "description": "作者头像" },
          "view": { "type": "string", "description": "播放量" },
          "like": { "type": "string", "description": "点赞数" },
          "reply": { "type": "string", "description": "评论数" },
          "favorite": { "type": "string", "description": "收藏数" },
          "coin": { "type": "string", "description": "投币数" },
          "duration": { "type": "integer", "description": "时长(秒)" },
          "pubdate": { "type": "integer", "description": "发布时间戳" }
        }
      },
      "HistoryItem": {
        "type": "object",
        "description": "历史上的今天条目",
        "properties": {
          "year": { "type": "integer", "description": "年份" },
          "title": { "type": "string", "description": "标题" },
          "desc": { "type": "string", "description": "描述" },
          "link": { "type": "string", "description": "链接" },
          "date": { "type": "string", "description": "日期 (MMDD)" }
        }
      },
      "SuggestData": {
        "type": "object",
        "description": "搜索联想数据",
        "properties": {
          "query": { "type": "string", "description": "查询词" },
          "suggestions": {
            "type": "array",
            "items": { "type": "string" },
            "description": "联想词列表"
          }
        }
      },
      "BaiduSearchData": {
        "type": "object",
        "description": "百度搜索结果数据",
        "properties": {
          "query": { "type": "string", "description": "查询词" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string", "description": "标题" },
                "link": { "type": "string", "description": "链接" },
                "description": { "type": "string", "description": "描述" },
                "date": { "type": "string", "description": "日期" }
              }
            }
          },
          "count": { "type": "integer", "description": "结果总数" },
          "source": { "type": "string", "description": "数据源", "example": "baidu" },
          "status": { "type": "string", "description": "状态", "example": "alpha" }
        }
      },
      "LunarData": {
        "type": "object",
        "description": "农历/黄历数据",
        "properties": {
          "date": { "type": "string", "description": "公历日期 (YYYY-MM-DD)" },
          "solar": {
            "type": "object",
            "description": "公历信息",
            "properties": {
              "year": { "type": "integer", "description": "年" },
              "month": { "type": "integer", "description": "月" },
              "day": { "type": "integer", "description": "日" },
              "weekday": { "type": "string", "description": "星期" },
              "weekdayIndex": { "type": "integer", "description": "星期索引 (0-6)" }
            }
          },
          "lunar": {
            "type": "object",
            "description": "农历信息",
            "properties": {
              "year": { "type": "integer", "description": "农历年" },
              "month": { "type": "integer", "description": "农历月" },
              "day": { "type": "integer", "description": "农历日" },
              "monthName": { "type": "string", "description": "农历月名称" },
              "dayName": { "type": "string", "description": "农历日名称" },
              "isLeapMonth": { "type": "boolean", "description": "是否闰月" },
              "yearShengXiao": { "type": "string", "description": "年生肖" },
              "monthShengXiao": { "type": "string", "description": "月生肖" },
              "dayShengXiao": { "type": "string", "description": "日生肖" }
            }
          },
          "ganzhi": {
            "type": "object",
            "description": "干支信息",
            "properties": {
              "year": { "type": "string", "description": "年干支" },
              "month": { "type": "string", "description": "月干支" },
              "day": { "type": "string", "description": "日干支" },
              "hour": { "type": "string", "description": "时干支" },
              "naYin": { "type": "string", "description": "日纳音" }
            }
          },
          "festivals": {
            "type": "object",
            "description": "节日信息",
            "properties": {
              "holiday": {
                "type": "array",
                "items": { "type": "string" },
                "description": "法定节假日"
              },
              "lunar": { "type": "string", "description": "农历节日" },
              "solar": { "type": "string", "description": "公历节日" },
              "computed": { "type": "string", "description": "计算得出的节日" }
            }
          },
          "solarTerm": {
            "type": "object",
            "description": "节气信息",
            "properties": {
              "current": { "type": "string", "description": "当前节气" },
              "displayName": { "type": "string", "description": "显示名称" },
              "status": { "type": "string", "description": "状态" }
            }
          },
          "yi": {
            "type": "array",
            "items": { "type": "string" },
            "description": "宜做的事"
          },
          "ji": {
            "type": "array",
            "items": { "type": "string" },
            "description": "忌做的事"
          },
          "chong": {
            "type": "object",
            "description": "冲煞信息",
            "properties": {
              "description": { "type": "string", "description": "冲的生肖" },
              "sha": { "type": "string", "description": "煞的方向" }
            }
          },
          "pengZu": {
            "type": "object",
            "description": "彭祖百忌",
            "properties": {
              "gan": { "type": "string", "description": "天干百忌" },
              "zhi": { "type": "string", "description": "地支百忌" }
            }
          },
          "zhiXing": {
            "type": "object",
            "description": "值日星神",
            "properties": {
              "value": { "type": "string", "description": "星神名称" },
              "description": { "type": "string", "description": "说明" }
            }
          },
          "liuYao": {
            "type": "object",
            "description": "六曜",
            "properties": {
              "value": { "type": "string", "description": "六曜名称" },
              "description": { "type": "string", "description": "说明" }
            }
          }
        }
      },
      "HotSource": {
        "type": "object",
        "description": "热搜来源",
        "properties": {
          "name": { "type": "string", "description": "平台名称" },
          "alias": { "type": "string", "description": "平台别名" },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "description": "标题" },
                "alias": { "type": "string", "description": "别名" },
                "url": { "type": "string", "description": "链接" },
                "hot": { "type": "string", "description": "热度" },
                "desc": { "type": "string", "description": "描述" }
              }
            },
            "description": "该平台的热搜列表"
          }
        }
      }
    }
  }
}
