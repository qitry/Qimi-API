{
  "name": "qimi-api",
  "version": "1.0.0",
  "description": "基于 Node.js/TypeScript 开发、符合 OpenAPI 规范的免费 API 服务集合",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "node dist/src/app.js",
    "build": "tsc",
    "test": "bash test_apis.sh",
    "lint": "eslint src/ lib/ --ext .ts",
    "lint:fix": "eslint src/ lib/ --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "node node_modules/husky/bin.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "lunar-javascript": "^1.7.7",
    "qrcode": "^1.5.4",
    "rapidoc": "^9.3.8",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/compression": "^1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-ejs-layouts": "^2",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  },
  "resolutions": {
    "undici": "^6.23.1"
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "@typescript-eslint/no-explicit-any": "warn",
      "no-console": "warn"
    },
    "ignorePatterns": [
      "node_modules",
      "dist",
      ".vercel",
      ".yarn"
    ]
  },
  "prettier": {
    "arrowParens": "avoid",
    "bracketSameLine": true,
    "bracketSpacing": true,
    "endOfLine": "lf",
    "printWidth": 100,
    "proseWrap": "preserve",
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
